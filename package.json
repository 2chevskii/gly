{
  "name": "@gly/docs",
  "version": "1.0.0",
  "author": "2CHEVSKII",
  "license": "MIT",
  "private": true,
  "description": "Custom visual formatting for PowerShell file system objects.",
  "type": "module",
  "scripts": {
    "test": "pwsh -NoProfile -File ./scripts/Invoke-Tests.ps1",
    "test:coverage": "pwsh -NoProfile -File ./scripts/Invoke-Tests.ps1 -Coverage",
    "report:ctrf": "junit-to-ctrf",
    "report:html": "ctrf-html-reporter",
    "module:publish:whatif": "pwsh -NoProfile -Command \"Publish-PSResource -Path ./src -Repository PSGallery -ApiKey $env:PSGALLERY_API_KEY -WhatIf -Verbose\"",
    "bench": "pwsh -NoProfile -File ./benchmarks/Invoke-GlyBenchmarks.ps1",
    "bench:startup": "pwsh -NoProfile -File ./benchmarks/Measure-GlyStartup.ps1",
    "bench:rendering": "pwsh -NoProfile -File ./benchmarks/Measure-GlyRendering.ps1",
    "bench:comparison": "pwsh -NoProfile -File ./benchmarks/Measure-ModuleComparison.ps1",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ctrf-html-reporter": "^1.1.22",
    "junit-to-ctrf": "^0.0.14",
    "vitepress": "^1.6.4"
  }
}
