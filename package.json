{
  "name": "@gly/docs",
  "version": "1.0.0",
  "author": "2CHEVSKII",
  "license": "MIT",
  "private": true,
  "description": "Custom visual formatting for PowerShell file system objects.",
  "type": "module",
  "scripts": {
    "module:pack": "pwsh -NoProfile -File ./scripts/New-GlyGalleryPackage.ps1 -Clean",
    "module:publish:whatif": "pwsh -NoProfile -Command \"./scripts/New-GlyGalleryPackage.ps1 -Clean | Out-Null; Publish-Module -Path ./artifacts/psgallery/gly -Repository PSGallery -NuGetApiKey $env:PSGALLERY_API_KEY -WhatIf -Verbose\"",
    "docs:dev": "vitepress dev docs/web",
    "docs:build": "vitepress build docs/web",
    "docs:preview": "vitepress preview docs/web"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "vitepress": "^1.6.4"
  }
}
